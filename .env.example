LLM_API_KEY=your_default_key_here

# Optional provider-specific keys (recommended when switching providers)
BYTEPLUS_API_KEY=your_byteplus_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
MIMO_API_KEY=your_mimo_key_here

# Optional live test controls (local only)
# Set to 1 only when you explicitly want to run live provider tests.
FRAMELAB_ENABLE_LIVE_TESTS=0

# Optional overrides for live smoke test target.
# If empty, live test uses config.toml defaults.provider and that provider's default model/base_url.
TEST_PROVIDER=
TEST_MODEL=
TEST_BASE_URL=
TEST_API_KEY=